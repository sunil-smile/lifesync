generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Frequency {
  DAILY
  WEEKLY
  CUSTOM
}

enum WorkoutType {
  RUNNING
  GYM
  YOGA
  CYCLING
  SWIMMING
  OTHER
}

enum IntensityLevel {
  LOW
  MEDIUM
  HIGH
}

enum InvestmentPlatform {
  INDIA_STOCK
  INDIA_MF
  US_STOCK
  OTHER
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  HOLD
  DONE
}

enum GoalType {
  LIFE
  LONG_TERM
  SHORT_TERM
  MILESTONE
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum NoteVisibility {
  PERSONAL
  SHARED
}

enum ProgressType {
  PERCENTAGE
  MILESTONE_BASED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  avatar      String   @default("?")
  bankName    String?
  xp          Int      @default(0)
  level       Int      @default(1)
  levelName   String   @default("Beginner")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  habits          Habit[]
  habitLogs       HabitLog[]
  workouts        Workout[]
  sleepLogs       SleepLog[]
  expenses        Expense[]
  incomes         Income[]
  budgetCategories BudgetCategory[]
  investments     Investment[]
  tasks           Task[]
  goals           Goal[]
  timeEntries     TimeEntry[]
  notes           Note[]
  xpLogs          XpLog[]
  bankUploadLogs  BankUploadLog[]
}

model Habit {
  id          String    @id @default(cuid())
  name        String
  icon        String
  color       String    @default("#3B82F6")
  frequency   Frequency
  targetDays  Int       @default(7)
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs        HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model Workout {
  id              String         @id @default(cuid())
  userId          String
  name            String
  type            WorkoutType
  durationMinutes Int
  distanceKm      Float?
  intensityLevel  IntensityLevel
  caloriesBurned  Int?
  notes           String?
  loggedAt        DateTime
  createdAt       DateTime       @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SleepLog {
  id            String   @id @default(cuid())
  userId        String
  bedtime       DateTime
  wakeTime      DateTime
  totalHours    Float
  qualityRating Int
  notes         String?
  loggedAt      DateTime
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  category    String
  description String
  date        DateTime
  paidBy      String   @default("sunil")
  bankAccount String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Income {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  source      String
  category    String
  date        DateTime
  receivedBy  String
  recurring   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BudgetCategory {
  id           String   @id @default(cuid())
  userId       String
  name         String
  icon         String?
  monthlyLimit Float
  alertAt      Int      @default(80)
  month        Int
  year         Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Investment {
  id             String             @id @default(cuid())
  userId         String
  name           String
  ticker         String?
  platform       InvestmentPlatform
  sector         String
  fundType       String?
  units          Float?
  buyPrice       Float?
  currentPrice   Float?
  investedAmount Float?
  currentValue   Float?
  purchaseDate   DateTime?
  currency       String             @default("EUR")
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id        String      @id @default(cuid())
  userId    String
  title     String
  notes     String?
  dueDate   DateTime?
  priority  TaskPriority @default(MEDIUM)
  assignee  String       @default("sunil")
  status    TaskStatus   @default(TODO)
  goalId    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal      Goal?        @relation(fields: [goalId], references: [id], onDelete: SetNull)
  updates   TaskUpdate[]
}

model TaskUpdate {
  id        String   @id @default(cuid())
  taskId    String
  text      String   @db.Text
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Goal {
  id             String       @id @default(cuid())
  userId         String
  title          String
  description    String?
  whyMotivation  String?
  type           GoalType
  category       String
  targetDate     DateTime?
  assignee       String       @default("sunil")
  progress       Int          @default(0)
  progressType   ProgressType @default(PERCENTAGE)
  targetValue    Float?
  targetUnit     String?
  parentGoalId   String?
  status         GoalStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentGoal     Goal?        @relation("GoalHierarchy", fields: [parentGoalId], references: [id], onDelete: SetNull)
  childGoals     Goal[]       @relation("GoalHierarchy")
  tasks          Task[]
  milestones     Milestone[]
}

model Milestone {
  id        String    @id @default(cuid())
  goalId    String
  title     String
  completed Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())

  goal      Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id              String    @id @default(cuid())
  userId          String
  description     String
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  category        String?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id         String         @id @default(cuid())
  userId     String
  title      String
  content    String         @db.Text
  tags       String[]
  visibility NoteVisibility @default(PERSONAL)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model XpLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  xpEarned  Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Quote {
  id         String   @id @default(cuid())
  text       String
  author     String?
  category   String?
  isFavorite Boolean  @default(false)
  userId     String?
  createdAt  DateTime @default(now())
}

model BankUploadLog {
  id               String   @id @default(cuid())
  userId           String
  accountType      String
  uploadedAt       DateTime
  transactionCount Int
  dateFrom         DateTime
  dateTo           DateTime

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
